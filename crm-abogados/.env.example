# Turso (producción) - obtén estos valores en app.turso.tech
TURSO_DATABASE_URL=libsql://tu-db-nombre.turso.io
TURSO_AUTH_TOKEN=tu-token-aqui

# Dejar vacío en desarrollo local (usa SQLite local automáticamente)

# Clerk Auth - obtén estas keys en dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Rutas de auth (no cambiar)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Asistente IA (Anthropic) - obtén tu API key en console.anthropic.com
# Si se deja vacía, el módulo IA mostrará un aviso de "no configurado".
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Modelo opcional (default: claude-sonnet-4-6)
AI_MODEL=claude-sonnet-4-6

# Lista blanca de acceso — separado por coma. Sin esta variable, el CRM queda abierto.
ALLOWED_EMAILS=abogado1@estudio.cl,abogado2@estudio.cl

# Plan Pro — separado por coma, subconjunto de ALLOWED_EMAILS.
# Sin esta variable, TODOS los clientes autorizados quedan en plan Básico
# (sin Asistente IA). Agregar aquí el correo de cada cliente que pagó Pro.
PLAN_PRO_EMAILS=abogado2@estudio.cl

# Cifrado de datos sensibles (credenciales de portal, cuenta bancaria) — Ley 21.719
# Clave de 32 bytes en base64. Generar UNA sola vez con: openssl rand -base64 32
# Nunca reutilizar este valor de ejemplo — cargar el valor real solo en Vercel.
ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Correo transaccional (Resend) - obtén tu API key en resend.com/api-keys
# SIN esta variable, TODOS los correos fallan en silencio: confirmaciones de
# citas, resumen diario, avisos de tareas pendientes, recordatorio de citas
# del día siguiente, y el aviso interno de accesos no autorizados. Verifica
# en resend.com → Emails que sí estén llegando — si dice "No sent emails
# yet" con esta variable puesta, la key es inválida o de otra cuenta.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Remitente de los correos. Sin esta variable usa onboarding@resend.dev
# (dominio genérico de Resend, con más riesgo de caer en spam). Para usar
# contacto@lexcrm.site hay que verificar el dominio lexcrm.site en Resend
# (registros SPF/DKIM en el proveedor de DNS) antes de configurarlo aquí.
RESEND_FROM_EMAIL=LexCRM <contacto@lexcrm.site>

# Autentica los cron jobs de Vercel (resumen diario, avisos de tareas,
# recordatorio de citas) y la notificación interna de accesos no
# autorizados. Vercel envía automáticamente este valor como header
# Authorization al invocar los crons — sin esta variable, todas las
# ejecuciones automáticas devuelven "No autorizado" y nunca llegan a
# intentar el envío. Cualquier texto aleatorio largo sirve, ej.:
# openssl rand -hex 16
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Sistema de pruebas gratuitas de 7 días (Fase 1) ──────────────────────────
# Interruptor de emergencia. Con "false" (o sin definir) el sistema de pruebas
# está DORMIDO: el CRM se comporta exactamente como hoy (acceso solo por
# ALLOWED_EMAILS). Ponlo en "true" recién cuando quieras abrir la puerta pública
# de pruebas (Fase 2), y solo DESPUÉS de agregar el metadata al token de sesión
# de Clerk (Dashboard → Sessions → Customize session token):
#   { "email": "{{user.primary_email_address}}", "metadata": "{{user.public_metadata}}" }
# Los usuarios actuales (en ALLOWED_EMAILS) nunca dependen de esta variable.
TRIALS_ENABLED=false

# Correos con acceso al panel de administración /admin (coma-separado). Solo
# estos usuarios pueden ver/activar/suspender cuentas de prueba y clientes.
# Sin esta variable, nadie tiene acceso al panel.
ADMIN_EMAILS=tu-correo@ejemplo.cl
